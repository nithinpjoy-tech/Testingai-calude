# ─────────────────────────────────────────────────────────────────────────────
# Test Triage Tool — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional overrides ────────────────────────────────────────────────────────

# Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Max tokens for triage analysis (default: 4096)
# TRIAGE_MAX_TOKENS=4096

# Max tokens for fix script generation (default: 4096)
# REMEDIATION_MAX_TOKENS=4096

# Execution environment: demo | staging | production
# APP_ENV=demo

# ── Notifications (optional — leave blank to disable) ─────────────────────────

# Slack incoming webhook URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Microsoft Teams incoming webhook URL
# TEAMS_WEBHOOK_URL=https://xxx.webhook.office.com/webhookb2/...
